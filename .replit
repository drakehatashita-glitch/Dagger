[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 25565
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Build plugin"

[[workflows.workflow]]
name = "Build plugin"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "mvn -B clean package && cp target/DaggerSMP-2.2.0.jar DaggerSMP-2.2.0.jar && echo Built target/DaggerSMP-2.2.0.jar"

[workflows.workflow.metadata]
outputType = "console"
